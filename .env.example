# PostgreSQL connection string
# Example for local dev: postgresql://user:password@localhost:5432/runtime_engine
# Example for Neon: postgresql://user:password@ep-xxx.neon.tech/neondb?sslmode=require
DATABASE_URL="postgresql://postgres:password@localhost:5432/runtime_engine"

# JWT secret for auth token signing — use a long random string in production
JWT_SECRET="change-this-to-a-long-random-secret-before-deploying"

# JWT expiry
JWT_EXPIRES_IN="7d"

# Node environment
NODE_ENV="development"
